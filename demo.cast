[0.056, "o", "\u001b[?2026h\u001b[2D\u001b[3B\r\u001b[6A\u001b[38;2;255;255;255m●\u001b[1C\u001b[39mYes — the summary already included an interaction check.\u001b[1CThere\u001b[1Cis\u001b[1C\u001b[1m1 known interaction\u001b[22m:\r\u001b[2B  \u001b[1m[MODERATE] Amlodipine + Simvastatin\u001b[22m\u001b[K\r\u001b[1B\u001b[K\r\u001b[2B\u001b[38;2;153;153;153m❯ \u001b[39m\u001b[7m \u001b[27m\u001b[K\r\r\n\u001b[38;2;136;136;136m──────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\n\u001b[2C\u001b[38;2;153;153;153mesc\u001b[1Cto\u001b[1Cinterrupt\u001b[39m\r\r\n\u001b[2C\u001b[3A\u001b[?2026l"]
[0.155, "o", "\u001b]0;⠐ Find all patients with last name Stokes\u0007"]
[0.051, "o", "\u001b[?2026h\u001b[2D\u001b[3B\r\u001b[2C\u001b[5AAmlodipine\u001b[1Craises\u001b[1Csimvastatin\u001b[1Cexposure,\u001b[1Cwhich\u001b[1Cincreases\u001b[1Cthe\u001b[1Crisk\u001b[1Cof\u001b[1Csimvastatin\u001b[1Cside\u001b[1Ceffects\u001b[1C(e.g.,\u001b[1Cmyopathy).\u001b[1CThe\u001b[1Csimvastatin\u001b[1Cdose\u001b[1Cmay\u001b[1Cneed\u001b[1Cto\u001b[1Cbe\u001b[1Climited.\r\u001b[1B\u001b[K\r\u001b[1B\u001b[38;2;136;136;136m──────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\r\u001b[1B\u001b[38;2;153;153;153m❯ \u001b[39m\u001b[7m \u001b[27m\u001b[K\r\u001b[1B\u001b[38;2;136;136;136m──────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\n\u001b[2C\u001b[38;2;153;153;153mesc\u001b[1Cto\u001b[1Cinterrupt\u001b[39m\r\r\n\u001b[2C\u001b[3A\u001b[?2026l"]
[0.607, "o", "\u001b[?2026h\u001b[2D\u001b[3B\r\u001b[4A  Her third medication, \u001b[1mferrous sulfate\u001b[22m, has no flagged interactions with either of the other two.\u001b[K\r\u001b[1B\u001b[K\r\u001b[2B\u001b[38;2;153;153;153m❯ \u001b[39m\u001b[7m \u001b[27m\u001b[K\r\r\n\u001b[38;2;136;136;136m──────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\n\u001b[2C\u001b[38;2;153;153;153mesc\u001b[1Cto\u001b[1Cinterrupt\u001b[39m\r\r\n\u001b[2C\u001b[3A\u001b[?2026l"]
